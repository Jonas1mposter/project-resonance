.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Hero Section */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A9E94, #3A8E84);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(74, 158, 148, 0.3);
}

.logo-icon {
  font-size: 64rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.8;
}

/* Enter Button */
.enter-btn {
  width: 80% !important;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #4A9E94, #3A8E84) !important;
  color: #fff !important;
  margin-bottom: 72rpx;
  border: none !important;
  box-shadow: 0 8rpx 24rpx rgba(74, 158, 148, 0.35);
  letter-spacing: 4rpx;
}

.enter-btn::after {
  border: none;
}

/* Features Grid */
.features {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 12rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.feature-desc {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

/* Footer */
.footer {
  margin-top: auto;
  padding-top: 48rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #ccc;
}
