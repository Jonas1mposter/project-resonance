.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #4A9E94;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo {
  width: 80rpx;
  height: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

.enter-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 16rpx;
  background: #4A9E94 !important;
  color: #fff;
  margin-bottom: 60rpx;
}

.features {
  display: flex;
  gap: 32rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  min-width: 160rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #333;
}
