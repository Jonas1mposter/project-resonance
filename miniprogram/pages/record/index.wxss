.record-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FDF8F3;
  padding: 40rpx;
}

.record-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 100%;
}

.hint-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

.sub-hint {
  font-size: 24rpx;
  color: #999;
}

.success-hint {
  color: #D4A017;
}

.record-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #E8832A;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232, 131, 42, 0.3);
  transition: transform 0.1s;
}

.record-btn:active {
  transform: scale(0.95);
}

.record-btn.recording {
  background: #ef4444;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
  animation: pulse-ring 1.5s ease-in-out infinite;
}

@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
  50% { box-shadow: 0 0 0 20rpx rgba(239, 68, 68, 0); }
}

.mic-icon {
  width: 80rpx;
  height: 80rpx;
}

.stop-icon {
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.recording-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #ef4444;
  font-weight: 500;
}

.pulse-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.duration-display {
  font-size: 64rpx;
  font-weight: 700;
  color: #333;
  font-variant-numeric: tabular-nums;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(232, 131, 42, 0.2);
  border-top-color: #E8832A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.status-text {
  font-size: 30rpx;
  color: #666;
}

.result-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(232, 131, 42, 0.08);
}

.error-card {
  background: #fef2f2;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.result-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.6;
}

.error-card .result-text {
  color: #ef4444;
  font-size: 30rpx;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: #fff;
  color: #333;
  border: 2rpx solid #e5e5e5;
}

.primary-btn {
  background: #E8832A;
  color: #fff;
  border: none;
}
